#include <stdio.h>
int main()
{
    int age;
    char citizen;
    printf("Enter age: ");
    scanf("%d", &age);
    if (age >= 18) {
        printf("Are you a citizen? (y/n): ");
        scanf(" %c", &citizen);
        if (citizen == 'y' || citizen == 'Y') {
            printf("Eligible to vote");
        } else {
            printf("Not eligible (Not a citizen)");
        }
    } else {
        printf("Not eligible (Age less than 18)");
    }
    return 0;
}
